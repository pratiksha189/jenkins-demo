pipeline {
  agent any
  enviornment{
    DOCKER_CRED = credentials("DockerHub")
}
stages{
    stage("fetch-code"){
        steps{
    git branch: 'main', url: "https://github.com/pratiksha189/jenkins-demo.git"
        }
  }
    stage('build-image'){
       steps{
    sh "docker build -t vj2151/jenkins-app:$(BUILD_NUMBER)" 
       }
    }
    stage('push-image'){
    sh "echo $DOCKER_CRED_PSW | docker login -u $DOCKER_CRED_USR --password-stdin"
    sh "docker push vj2151/jenkins-app:$(BUILD_NUMBER)"
    }
}
stage('update-minikube'){
steps{
  sh "kubectl set image deployment/pd1 jenkins-app="vj2151/jenkins-app:$(BUILD_NUMBER)"
}
}
}
